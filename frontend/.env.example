# Client-side (visible in browser)
NEXT_PUBLIC_API_URL=         # Leave empty to use Next.js rewrite
NEXT_PUBLIC_WS_URL=          # Leave empty to auto-detect from window.location
NEXT_PUBLIC_BACKEND_PORT=42001  # WS direct connection port (must match BACKEND_PORT)

# Server-side (Server Component / SSR)
BACKEND_INTERNAL_URL=http://localhost:42001   # Docker: http://backend:8000
