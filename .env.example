# ===========================================
# Usami Environment Configuration
# Copy this file to .env and fill in your keys
# ===========================================

# --- LLM API Keys (至少配置一个) ---
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# --- Database ---
POSTGRES_USER=agenticOS
POSTGRES_PASSWORD=agenticOS
POSTGRES_DB=agenticOS
DATABASE_URL=postgresql://agenticOS:agenticOS@postgres:5432/agenticOS

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- LiteLLM ---
LITELLM_PROXY_URL=http://litellm:4000

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Ports (避免多项目冲突，按需修改) ---
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
LITELLM_PORT=4000
