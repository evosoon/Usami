# ===========================================
# Usami Environment Configuration
# Copy this file to .env and fill in your keys
# ===========================================

# --- LLM API Keys (至少配置一个) ---
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# --- Database ---
POSTGRES_USER=usami
POSTGRES_PASSWORD=usami
POSTGRES_DB=usami
DATABASE_URL=postgresql://usami:usami@postgres:5432/usami

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- LiteLLM ---
LITELLM_PROXY_URL=http://litellm:4000
LITELLM_MASTER_KEY=sk-usami-dev

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Auth ---
JWT_SECRET=change-me-in-production
ADMIN_EMAIL=admin@usami.local
ADMIN_PASSWORD=admin123
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Push Notifications (optional) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:admin@usami.local

# --- Ports (42xxx 前缀避免与常见开发工具冲突，绑定 127.0.0.1 只允许本机访问) ---
BACKEND_PORT=42001
FRONTEND_PORT=42000
POSTGRES_PORT=42432      # 默认不暴露，需要时在 docker-compose.yml 取消注释
REDIS_PORT=42379         # 默认不暴露，需要时在 docker-compose.yml 取消注释
LITELLM_PORT=42002
SEARXNG_PORT=42080

# --- CORS ---
CORS_ORIGINS=http://localhost:42000
