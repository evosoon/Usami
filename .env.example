# ===========================================
# Usami Environment Configuration
# Copy this file to .env and fill in your keys
# ===========================================

# --- LLM API Keys (至少配置一个) ---
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# --- Database ---
POSTGRES_USER=usami
POSTGRES_PASSWORD=usami
POSTGRES_DB=usami
DATABASE_URL=postgresql://usami:usami@postgres:5432/usami

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- LiteLLM ---
LITELLM_PROXY_URL=http://litellm:4000
LITELLM_MASTER_KEY=sk-usami-dev

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Auth ---
JWT_SECRET=change-me-in-production
ADMIN_EMAIL=admin@usami.local
ADMIN_PASSWORD=admin123
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Ports (避免多项目冲突，按需修改) ---
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
LITELLM_PORT=4000
